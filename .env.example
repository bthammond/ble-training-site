MAILCHIMP_API_KEY=your-mailchimp-api-key-here
MAILCHIMP_AUDIENCE_ID=your-audience-id-here
MAILCHIMP_SERVER=us22
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# BLE TimeClock public locations-status API (used by /locations to
# render live "Open Now" + today's hours from the live schedule).
# When TIMECLOCK_API_URL is unset, /locations gracefully falls back
# to the static weekly schedule in src/lib/locations.ts.
TIMECLOCK_API_URL=https://ble-timeclock.fly.dev
# Optional shared secret. Leave blank to use the endpoint open (the
# payload contains no sensitive data). Must match PUBLIC_API_KEY set
# on the TimeClock side.
TIMECLOCK_API_KEY=
